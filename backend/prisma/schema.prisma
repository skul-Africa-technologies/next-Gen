generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model Student {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  school    String?
  role      String   @default("student")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  interestedEvents String[] @default([])
}

model Event {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  date        DateTime
  image       String?
  location    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  interestedBy String[] @default([])
}
